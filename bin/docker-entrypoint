#!/bin/bash -e

seed_enabled() {
  case "${RUN_SEEDS:-false}" in
    true|TRUE|1|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

echo "Preparing database..."
./bin/rails db:prepare

if seed_enabled; then
  echo "RUN_SEEDS enabled; seeding database..."
  ./bin/rails db:seed
else
  echo "RUN_SEEDS disabled; skipping database seed."
fi

exec "${@}"
