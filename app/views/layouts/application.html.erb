<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title).presence || "Comuh" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Comuh — share ideas with your community">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Comuh">
    <meta name="turbo-cache-control" content="no-cache">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application_ui", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="bg-gray-50 antialiased min-h-screen">

    <%# Navbar %>
    <header class="bg-white border-b border-gray-200 sticky top-0 z-30 shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
        <%= link_to root_path, class: "flex items-center" do %>
          <%= image_tag "logo.png", alt: "Comuh", class: "h-10 w-auto" %>
        <% end %>

        <nav class="flex items-center gap-4 text-sm">
          <%= link_to "Communities", communities_path,
                class: "text-gray-600 hover:text-indigo-600 font-medium transition-colors" %>
        </nav>
      </div>
    </header>

    <%# Page content %>
    <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
      <% if flash[:alert].present? %>
        <div class="mb-6 flex items-center gap-3 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert">
          <span>⚠️</span> <%= flash[:alert] %>
        </div>
      <% end %>
      <% if flash[:notice].present? %>
        <div class="mb-6 flex items-center gap-3 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700" role="status">
          <span>✓</span> <%= flash[:notice] %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="border-t border-gray-200 mt-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-6 text-center text-xs text-gray-400">
        Comuh &mdash; Community Hub
      </div>
    </footer>

    <%# Username modal (shown by reaction_controller when localStorage is empty) %>
    <div id="username-modal"
         class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
         role="dialog"
         aria-modal="true"
         aria-labelledby="username-modal-title">
      <div class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm" id="username-modal-backdrop"></div>
      <div class="relative bg-white rounded-xl shadow-xl w-full max-w-sm p-6">
        <h3 id="username-modal-title" class="text-base font-semibold text-gray-900 mb-1">Choose a username</h3>
        <p class="text-sm text-gray-500 mb-4">You need a username to react to messages. It will be saved for future interactions.</p>
        <form id="username-modal-form" novalidate>
          <input
            id="username-modal-input"
            type="text"
            placeholder="your_username"
            autocomplete="username"
            maxlength="30"
            class="w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 focus:outline-none mb-1"
          >
          <p id="username-modal-error" class="text-xs text-red-500 mb-3 hidden">Please enter a username.</p>
          <div class="flex gap-3 justify-end mt-4">
            <button type="button" id="username-modal-cancel"
                    class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
              Cancel
            </button>
            <button type="submit"
                    class="px-4 py-2 text-sm font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
              Confirm
            </button>
          </div>
        </form>
      </div>
    </div>

  </body>
</html>
